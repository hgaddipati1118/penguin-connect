# PenguinConnect environment
# Copy this file to .env
#   cp .env.example .env

# Local bridge API port (default 9000)
PENGUIN_CONNECT_PORT=9000

# Local data directory and SQLite DB path
# PENGUIN_CONNECT_DATA_DIR=~/penguinconnect-local-bridge-data
# PENGUIN_CONNECT_DB_PATH=~/penguinconnect-local-bridge-data/cache.db

# Poll interval in seconds for incremental sync (default 30)
PENGUIN_CONNECT_POLL_SECONDS=30

# Optional cap for startup catch-up. Leave unset to drain all pending bootstrap conversations on server start.
# PENGUIN_CONNECT_STARTUP_CATCHUP_CONVERSATIONS_PER_RUN=5

# iMessage -> Gmail backfill pacing (seconds between Gmail writes in backfill/startup modes; default 0.15)
PENGUIN_CONNECT_BACKFILL_WRITE_PAUSE_SECONDS=0.15

# Durable sync queue (survives process pauses/restarts)
# Max attempts before marking sync job failed (default 12)
PENGUIN_CONNECT_SYNC_JOB_MAX_ATTEMPTS=12
# Lease timeout in seconds before another worker can resume a stuck job (default 180)
PENGUIN_CONNECT_SYNC_JOB_LEASE_SECONDS=180
# Retry backoff base/max in seconds for failed sync jobs (defaults 30/1800)
PENGUIN_CONNECT_SYNC_JOB_RETRY_BASE_SECONDS=30
PENGUIN_CONNECT_SYNC_JOB_RETRY_MAX_BACKOFF_SECONDS=1800

# Retry/backoff policy for failed cross-channel deliveries
# Base retry delay in seconds (default 30)
PENGUIN_CONNECT_RETRY_BASE_SECONDS=30
# Max exponential backoff delay in seconds (default 900)
PENGUIN_CONNECT_RETRY_MAX_BACKOFF_SECONDS=900
# Max retry attempts per message before marking failed_permanent (default 8)
PENGUIN_CONNECT_MAX_RETRIES=8
# Max retry attempts for Gmail-to-chat delivery before posting a failure notice (default 3)
PENGUIN_CONNECT_GMAIL_TO_SOURCE_MAX_RETRIES=3

# Max iMessage chats discovered into conversation mapping (default 500)
PENGUIN_CONNECT_CHAT_DISCOVERY_LIMIT=500

# Safety window before stale alias-only Gmail drafts in non-canonical threads are deleted (default 30 minutes)
# PENGUIN_CONNECT_ALIAS_DRAFT_DELETE_MINUTES=30

# Step 1: Google OAuth Desktop JSON path override (optional)
# PENGUIN_CONNECT_GOOGLE_CLIENT_SECRETS=~/penguinconnect-local-bridge-data/google_client_secret.json

# Optional path to a local JSON file containing custom email signature/disclaimer cutoff markers.
# The default path is ./.penguin_connect_signature_markers.json
# See ./signature_markers.example.json for file format.
# PENGUIN_CONNECT_SIGNATURE_MARKERS_FILE=/abs/path/to/signature_markers.json

# Optional local API base override used by scripts/penguin_connect_doctor.py
# PENGUIN_CONNECT_LOCAL_API_BASE=http://127.0.0.1:9000

# Bootstrap only: temporarily allow startup before Gmail OAuth is connected.
# Do not leave this enabled for normal operation.
# PENGUIN_CONNECT_ALLOW_MISSING_GMAIL_STARTUP=1
